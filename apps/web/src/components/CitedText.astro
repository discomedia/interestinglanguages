---
import { sourceIdsOf, textOf, type CitedText, type ContentSource } from "@interesting-languages/content";

interface Props {
  value: CitedText;
  sources: ContentSource[];
}

const { value, sources } = Astro.props;
const sourceIds = [...new Set(sourceIdsOf(value))];
const references = sourceIds
  .map((id) => ({ id, number: sources.findIndex((source) => source.id === id) + 1 }))
  .filter((reference) => reference.number > 0);
---

<>{textOf(value)}{references.length > 0 && <sup class="citations">{references.map((reference, index) => <><a href={`#source-${reference.id}`} aria-label={`Source ${reference.number}`}>{reference.number}</a>{index < references.length - 1 && ","}</>)}</sup>}</>
