---
import { LanguageSearch } from "../components/LanguageSearch";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchLanguageGuideSummaries, siteUrl } from "../lib/content";

const guides = await fetchLanguageGuideSummaries();
const title = "Interesting Languages";
const description = "Source-backed language reference guides for advanced learners.";
---

<BaseLayout title={title} description={description} canonical={siteUrl("/")}>
  <SiteHeader />
  <main>
    <section class="reference-hero">
      <div>
        <h1>Interesting Languages</h1>
        <p>
          A language reference for serious learners: origins, scripts, pronunciation, grammar,
          variants, relationships, useful words, and advanced study paths.
        </p>
      </div>
    </section>
    <LanguageSearch guides={guides} client:load />
  </main>
  <SiteFooter />
</BaseLayout>
