---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchLanguageGuide, fetchLanguageGuideSummaries, siteUrl } from "../lib/content";

export async function getStaticPaths() {
  const summaries = await fetchLanguageGuideSummaries();
  return summaries.map((guide) => ({
    params: { slug: guide.slug }
  }));
}

const { slug } = Astro.params;
const guide = slug ? await fetchLanguageGuide(slug) : undefined;

if (!guide) {
  return Astro.redirect("/");
}

const canonical = siteUrl(`/${guide.slug}`);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: guide.seo.title,
  description: guide.seo.description,
  mainEntityOfPage: canonical,
  datePublished: guide.publishedAt,
  about: {
    "@type": "Language",
    name: guide.name,
    alternateName: guide.autonym
  }
};

const nav = [
  ["origins", "Origins"],
  ["speakers", "Speakers"],
  ["pronunciation", "Pronunciation"],
  ["grammar", "Grammar"],
  ["writing", "Writing"],
  ["words", "Words"],
  ["relationships", "Relationships"],
  ["learning", "Advanced learning"],
  ["difficulty", "Difficulty"],
  ["sources", "Sources"]
];
---

<BaseLayout title={guide.seo.title} description={guide.seo.description} canonical={canonical} image={guide.seo.socialImageUrl}>
  <SiteHeader />
  <main>
    <article class="reference-entry">
      <header class="entry-header">
        <p><a href="/">Languages</a> / {guide.macroRegion}</p>
        <h1>{guide.name}</h1>
        {guide.autonym && <p class="autonym">{guide.autonym}</p>}
        <p class="dek">{guide.learnerOverview}</p>
      </header>

      <div class="entry-layout">
        <aside class="entry-nav" aria-label={`${guide.name} guide sections`}>
          {nav.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
        </aside>

        <div class="entry-body">
          <section class="fact-table" aria-label={`${guide.name} quick facts`}>
            {guide.facts.map((fact) => (
              <div>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </section>

          <section id="origins" class="entry-section">
            <h2>Origins</h2>
            <p>{guide.origins.overview}</p>
            <ol class="timeline">
              {guide.origins.timeline.map((item) => (
                <li>
                  <strong>{item.period}</strong>
                  <span>{item.event}</span>
                </li>
              ))}
            </ol>
            <p>{guide.origins.contactHistory}</p>
            <p>{guide.origins.standardization}</p>
          </section>

          <section id="speakers" class="entry-section">
            <h2>Speakers And Variants</h2>
            <p>{guide.whereSpoken.overview}</p>
            <ul class="compact-list">
              {guide.whereSpoken.regions.map((region) => (
                <li><strong>{region.place}</strong><span>{region.note}</span></li>
              ))}
            </ul>
            <p>{guide.variants.overview}</p>
            <div class="note-list">
              {guide.variants.items.map((variant) => (
                <article>
                  <h3>{variant.name}</h3>
                  <p>{variant.note}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="pronunciation" class="entry-section">
            <h2>Pronunciation</h2>
            <p>{guide.pronunciation.overview}</p>
            <dl class="definition-list">
              <div><dt>Sound system</dt><dd>{guide.pronunciation.soundSystem}</dd></div>
              <div><dt>Prosody</dt><dd>{guide.pronunciation.prosody}</dd></div>
              <div><dt>Learner traps</dt><dd>{guide.pronunciation.learnerTraps.join("; ")}.</dd></div>
            </dl>
            <div class="example-grid">
              {guide.pronunciation.sampleWords.map((word) => (
                <article>
                  <h3>{word.original}</h3>
                  {word.transliteration && <p>{word.transliteration}</p>}
                  <p>{word.translation}</p>
                  {word.note && <p class="muted">{word.note}</p>}
                </article>
              ))}
            </div>
          </section>

          <section id="grammar" class="entry-section">
            <h2>Grammar</h2>
            <p>{guide.grammar.typologicalProfile}</p>
            <p>{guide.grammar.morphology}</p>
            <p>{guide.grammar.syntax}</p>
            <div class="note-list">
              {guide.grammar.topics.map((topic) => (
                <article>
                  <h3>{topic.title}</h3>
                  <p>{topic.body}</p>
                  {topic.example && (
                    <p class="example">
                      <strong>{topic.example}</strong>
                      {topic.exampleTranslation && <span>{topic.exampleTranslation}</span>}
                    </p>
                  )}
                </article>
              ))}
            </div>
          </section>

          <section id="writing" class="entry-section">
            <h2>Writing System</h2>
            <p>{guide.writing.overview}</p>
            <dl class="definition-list">
              <div><dt>Primary script</dt><dd>{guide.writing.primaryScript}</dd></div>
              {guide.writing.romanization && <div><dt>Romanization</dt><dd>{guide.writing.romanization}</dd></div>}
              <div><dt>Spelling norms</dt><dd>{guide.writing.spellingNorms}</dd></div>
            </dl>
            <ul class="compact-list">
              {guide.writing.styleNotes.map((note) => <li>{note}</li>)}
            </ul>
          </section>

          <section id="words" class="entry-section">
            <h2>Words And Texts</h2>
            <p>{guide.wordsAndTexts.overview}</p>
            <p>{guide.wordsAndTexts.loanwordLayers}</p>
            <div class="example-grid">
              {guide.wordsAndTexts.notableWords.map((word) => (
                <article>
                  <h3>{word.term}</h3>
                  {word.transliteration && <p>{word.transliteration}</p>}
                  <p>{word.meaning}</p>
                  <p class="muted">{word.note}</p>
                </article>
              ))}
            </div>
            <p><strong>Useful genres:</strong> {guide.wordsAndTexts.textGenres.join(", ")}.</p>
          </section>

          <section id="relationships" class="entry-section">
            <h2>Related Languages</h2>
            <p>{guide.relationships.overview}</p>
            <div class="note-list">
              {guide.relationships.languages.map((language) => (
                <article>
                  <h3>{language.name}</h3>
                  <p><strong>{language.relationship}</strong> {language.explanation}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="learning" class="entry-section">
            <h2>Advanced Learning Path</h2>
            <p>{guide.advancedLearning.strategy}</p>
            <p>{guide.advancedLearning.mediaPractice}</p>
            <p>{guide.advancedLearning.dictionariesAndCorpora}</p>
            <div class="resource-list">
              {guide.advancedLearning.resources.map((resource) => (
                <article>
                  <span>{resource.type} / {resource.level}</span>
                  <h3>{resource.url ? <a href={resource.url}>{resource.title}</a> : resource.title}</h3>
                  <p>{resource.description}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="difficulty" class="entry-section">
            <h2>Difficulty</h2>
            <p>{guide.difficulty.overview}</p>
            <dl class="definition-list">
              <div><dt>Easier</dt><dd>{guide.difficulty.easierAspects.join("; ")}.</dd></div>
              <div><dt>Harder</dt><dd>{guide.difficulty.hardAspects.join("; ")}.</dd></div>
              <div><dt>Plateau risks</dt><dd>{guide.difficulty.plateauRisks.join("; ")}.</dd></div>
              <div><dt>Workload</dt><dd>{guide.difficulty.workload}</dd></div>
            </dl>
          </section>

          <section id="sources" class="entry-section sources">
            <h2>Sources</h2>
            <ul>
              {guide.sources.map((source) => (
                <li>
                  {source.url ? <a href={source.url}>{source.title}</a> : source.title}
                  {source.publisher && <> — {source.publisher}</>}
                </li>
              ))}
            </ul>
          </section>
        </div>
      </div>
    </article>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </main>
  <SiteFooter />
</BaseLayout>
